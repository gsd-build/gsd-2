{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GSD Mission Control",
  "version": "0.1.0",
  "identifier": "com.mzansiagentive.gsd-mission-control",
  "build": {
    "beforeDevCommand": "bun run --cwd packages/mission-control dev",
    "devUrl": "http://localhost:4000",
    "beforeBuildCommand": "bun run --cwd packages/mission-control build"
  },
  "app": {
    "windows": [
      {
        "title": "GSD Mission Control",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self' http://localhost:4000; connect-src http://localhost:4000 ws://localhost:4001 ws://localhost:* 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["dep_screen.html"]
  },
  "plugins": {
    "window-state": {
      "stateFlags": 31
    },
    "protocol": {
      "asset": true,
      "assetScope": {
        "allow": ["**"],
        "deny": []
      }
    }
  }
}
